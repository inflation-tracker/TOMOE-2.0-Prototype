# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=tomoe_db
POSTGRES_USER=tomoe
POSTGRES_PASSWORD=your_secret_here

# ─── Next.js Frontend ────────────────────────────────────────────
DATABASE_URL=postgresql://tomoe:your_secret_here@localhost:5432/tomoe_db
NEXT_PUBLIC_ML_URL=http://localhost:8000

# ─── ML Service ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
LOG_LEVEL=INFO
INDOBERT_MODEL=indobenchmark/indobert-base-p2
MODEL_DIR=/app/models

# ─── BPS API (optional) ──────────────────────────────────────────
BPS_API_KEY=your_bps_api_key_here
