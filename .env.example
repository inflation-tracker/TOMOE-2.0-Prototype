# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=tomoe_db
POSTGRES_USER=tomoe
POSTGRES_PASSWORD=your_secret_here

# ─── Next.js Frontend ────────────────────────────────────────────
DATABASE_URL=postgresql://tomoe:your_secret_here@localhost:5432/tomoe_db
# Server-side base URL the frontend uses to reach the ML service (NOT public).
ML_INTERNAL_URL=http://localhost:8000
# Secret injected server-side by the ML proxy routes; must match the ML API_KEY.
ML_API_KEY=
# HMAC secret for session JWTs — generate a long random value in production.
AUTH_SECRET=dev-insecure-secret-change-me
# Set to "true" in production to require auth on the entire /api surface.
AUTH_REQUIRED=false

# ─── ML Service ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
LOG_LEVEL=INFO
# Fine-tuned Indonesian sentiment classifier (not a bare base LM).
INDOBERT_MODEL=mdhugol/indonesia-bert-sentiment-classification
MODEL_DIR=/app/models
# Shared secret for the ML endpoints. Leave empty in dev to disable auth.
ML_API_KEY=

# ─── BPS API (optional) ──────────────────────────────────────────
BPS_API_KEY=your_bps_api_key_here
